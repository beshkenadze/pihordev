datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

plugin encryption {
  provider = "zenstack-encryption"
}

// ─── Organization ────────────────────────────────────────

model Organization {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  defaultModel String  @default("claude-sonnet-4-6")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members  Member[]
  teams    Team[]
  projects Project[]
  tasks    Task[]
  apiKeys  ApiKey[]

  @@map("organization")
}

// ─── Team ────────────────────────────────────────────────

model Team {
  id    String @id @default(cuid())
  name  String
  orgId String

  org     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  members Member[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, name])
  @@map("team")
}

// ─── User ────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  memberships Member[]
  tasks       Task[]     @relation("createdBy")
  apiKeys     ApiKey[]   @relation("createdBy")

  @@map("user")
}

// ─── Member (org membership join) ────────────────────────

model Member {
  id     String @id @default(cuid())
  role   String @default("member") // owner | admin | member
  orgId  String
  userId String
  teamId String?

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  team Team?        @relation(fields: [teamId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([orgId, userId])
  @@map("member")
}

// ─── Project ─────────────────────────────────────────────

model Project {
  id          String  @id @default(cuid())
  name        String
  description String?
  repoUrl     String
  orgId       String

  org   Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  tasks Task[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("project")
}

// ─── Task ────────────────────────────────────────────────

model Task {
  id          String @id @default(cuid())
  title       String
  description String?
  status      String @default("pending") // pending | queued | running | done | error | cancelled
  model       String @default("claude-sonnet-4-6")
  projectId   String
  orgId       String
  createdById String

  project   Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy User         @relation("createdBy", fields: [createdById], references: [id])
  agent     AgentInstance?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("task")
}

// ─── Agent Instance ──────────────────────────────────────

model AgentInstance {
  id        String    @id @default(cuid())
  taskId    String    @unique
  sandboxId String?
  status    String    @default("starting") // starting | running | done | error
  startedAt DateTime?
  stoppedAt DateTime?

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("agent_instance")
}

// ─── API Key ─────────────────────────────────────────────

model ApiKey {
  id          String    @id @default(cuid())
  name        String
  keyHash     String    @unique
  keyPreview  String
  keyValue    String?   @encrypted
  orgId       String
  createdById String
  lastUsedAt  DateTime?
  revokedAt   DateTime?

  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  createdBy User         @relation("createdBy", fields: [createdById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("api_key")
}
