{
	"name": "@repo/db",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"exports": {
		".": {
			"types": "./src/index.ts",
			"default": "./src/index.ts"
		}
	},
	"scripts": {
		"build": "tsc --build",
		"typecheck": "tsc --noEmit",
		"db:generate": "zen generate --schema zenstack/schema.zmodel",
		"db:migrate": "zen migrate up"
	},
	"dependencies": {
		"@zenstackhq/orm": "^3",
		"pg": "^8",
		"zenstack-encryption": "^0.2.1"
	},
	"devDependencies": {
		"@zenstackhq/cli": "^3"
	}
}
